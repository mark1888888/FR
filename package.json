{
  "name": "richmark",
  "version": "1.9.9",
  "description": "RichMark — 個人記帳理財 × 投資追蹤 × 財務 RPG",
  "main": "index.html",
  "scripts": {
    "cap:init": "cap init RichMark com.richmark.app --web-dir=.",

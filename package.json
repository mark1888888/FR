    "twa:build": "bubblewrap build"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/android": "^6.1.0",
    "@bubblewrap/cli": "^1.21.0"
  },
  "keywords": [
    "richmark",
    "pwa",
    "finance",
    "budget",
    "taiwan"
  ],
